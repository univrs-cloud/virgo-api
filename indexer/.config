# ZFS Indexer configuration

# SQLite database path
DB_PATH=/messier/.config/index.db

# Comma-separated dataset prefixes to include (children are included).
# Only datasets matching one of these prefixes will be indexed.
# Pool name is derived from the first prefix automatically.
DATASETS=messier/apps,messier/folders

# Comma-separated datasets to exclude (children are excluded too).
# Checked before DATASETS — takes priority.
# Supports globs: * matches any chars, ? matches single char.
# Examples: messier/apps/ghost-va, messier/apps/ghost-*, messier/apps/test-?
EXCLUDE_DATASETS=messier/apps/pcp,messier/apps/nextcloud-*,messier/apps/onlyoffice,messier/apps/gitea*,messier/apps/dockhand,messier/apps/ghost-*
